# ── Global rules only — per-app rules live in agent/, gateway/, web/ .gitignore ──

# OS
.DS_Store

# Editors / AI tooling
.vscode/
.kiro/
.claude/
.cursorignore
.cursorindexingignore

# Environment files — never commit secrets
.env
.env.*
.envrc

# Logs
*.log

# Ingestion dedup state (machine-local)
data/.dedup_state.json

# Node (any app level)
node_modules/
